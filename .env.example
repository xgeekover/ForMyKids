# ForMyKids 백엔드 → 외부 MariaDB(원격 서버의 도커 컨테이너 'mariadb-server') 접속 정보
# ───────────────────────────────────────────────────────────────────────────
# 실제 값은 이 파일을 복사해 `.env` 로 두세요(.env 는 .gitignore 됨 → 비밀번호 커밋 방지).
# .env 가 없으면 docker-compose.yml 의 기본값이 사용됩니다.
#   cp .env.example .env   후 값 수정

# (기본·B) 컨테이너 간 직접 통신 — backend 가 mariadb-server 와 같은 도커 네트워크에 참여
DB_HOST=mariadb-server
DB_PORT=3306
DB_USER=fmk_user
DB_PASSWORD=
DB_NAME=formykids

# mariadb-server 가 속한 외부 도커 네트워크 이름(기본 mariadb_default).
#   확인: docker inspect -f '{{range $k,$v := .NetworkSettings.Networks}}{{$k}} {{end}}' mariadb-server
MARIADB_NETWORK=mariadb_default

# (대안·A) 컨테이너 간 통신이 어려우면 호스트 게시 포트로 접속하도록 위 DB_HOST/DB_PORT 를 교체:
#   DB_HOST=<원격서버 IP>   (또는 host.docker.internal)
#   DB_PORT=3336

# ── 배포 대상 (로컬 전용 · 커밋/전송 안 됨) ──────────────────────────────
# 서버 주소/계정/SSH 비밀번호는 이 .env(원격으로 scp 됨)가 아니라 별도의 .env.deploy 에 두세요.
# .env.deploy 는 .gitignore 되며 deploy.sh 가 로컬에서만 읽고 원격으로 전송하지 않습니다. 예:
#   FMK_REMOTE=<계정>@<원격서버 IP>
#   FMK_SSH_PORT=<SSH 포트>
#   FMK_SSH_PASS=<SSH 비밀번호>      # 키 인증이면 생략
