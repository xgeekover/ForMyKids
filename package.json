{
  "name": "formykids",
  "private": true,
  "version": "1.0.0",
  "description": "ForMyKids — 7~8세용 통합 게임 플랫폼 (런처 + 게임들을 한 번에 빌드하는 Vite 멀티페이지 앱)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --port 8080",
    "test:store": "node shared/fmk-store.test.mjs",
    "test:sound": "node shared/fmk-sound.test.mjs",
    "test:syncqueue": "node shared/fmk-syncqueue.test.mjs",
    "test:dashboard": "node shared/fmk-dashboard.test.mjs",
    "test:coop": "node shared/fmk-coop.test.mjs",
    "test:passport": "node shared/fmk-passport.test.mjs",
    "test:maze": "node games/maze/maze-logic.test.mjs",
    "test:spot": "node games/spot/spot-logic.test.mjs",
    "test:puzzle": "node games/puzzle/puzzle-logic.test.mjs",
    "test:memory": "node games/memory/src/gameLogic.test.mjs",
    "test": "node shared/fmk-store.test.mjs && node shared/fmk-sound.test.mjs && node shared/fmk-syncqueue.test.mjs && node shared/fmk-dashboard.test.mjs && node shared/fmk-coop.test.mjs && node shared/fmk-passport.test.mjs && node games/maze/maze-logic.test.mjs && node games/spot/spot-logic.test.mjs && node games/puzzle/puzzle-logic.test.mjs && node games/memory/src/gameLogic.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "deploy": "bash deploy.sh"
  },
  "dependencies": {
    "framer-motion": "^11.11.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^5.4.11"
  }
}
