# ===================================================================
# ForMyKids · Git ignore
# (커밋해야 하는 것: 소스, docker-compose.yml, Dockerfile, deploy.sh,
#  .dockerignore, .env.example, package-lock.json …)
# ===================================================================

# ── 의존성(루트·backend 등 어느 위치든) ──
node_modules/

# ── 빌드 산출물 ──
dist/
dist-ssr/
build/

# ── 비밀/환경값 — 템플릿(.env.example)만 커밋, 실제 .env* 는 제외 ──
# (.env 에는 외부 MariaDB 비밀번호 등 민감정보가 들어감)
.env
.env.*
!.env.example

# ── 테스트 / 커버리지 산출물 (Playwright 등) ──
test-results/
playwright-report/
blob-report/
playwright/.cache/
coverage/

# ── 캐시 / 로컬 전용 ──
.vite/
*.local

# ── 로그 ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Docker — 로컬 DB 볼륨(레거시)·이미지 덤프 ──
db_data/
*.tar
*.tar.gz

# ── OS / 에디터 ──
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~
